---
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconGlobe from "@/assets/icons/IconGlobe.svg";
import IconMedium from "@/assets/icons/IconMedium.svg";
import LinkButton from "./LinkButton.astro";

type Props = {
  githubURL?: string;
  mediumURL?: string;
  liveURL?: string;
};

const { githubURL, mediumURL, liveURL } = Astro.props;

type ProjectLink = {
  name: "GitHub" | "Medium" | "Live App";
  href: string;
  icon: typeof IconGitHub;
};

const links: ProjectLink[] = [];

if (githubURL?.trim()) {
  links.push({ name: "GitHub", href: githubURL.trim(), icon: IconGitHub });
}

if (mediumURL?.trim()) {
  links.push({ name: "Medium", href: mediumURL.trim(), icon: IconMedium });
}

if (liveURL?.trim()) {
  links.push({ name: "Live App", href: liveURL.trim(), icon: IconGlobe });
}
---

{
  links.length > 0 && (
    <div class="flex flex-none flex-col items-center justify-center gap-2 md:items-start">
      <span class="italic">View the project on:</span>
      <div class="flex flex-wrap justify-center gap-2 md:justify-start">
        {links.map(link => (
          <LinkButton
            href={link.href}
            class="p-2 hover:rotate-6"
            target="_blank"
            rel="noopener noreferrer"
            title={`Open project on ${link.name}`}
          >
            <link.icon class="inline-block size-5 opacity-95 transition-transform group-hover:scale-105" />
            <span class="sr-only">{link.name}</span>
          </LinkButton>
        ))}
      </div>
    </div>
  )
}

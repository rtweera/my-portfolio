---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SOCIALS } from "@/constants";
import { HOME_PAGE_CONTENT } from "@/data/home";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const { hero, about, currently, focusAreas } = HOME_PAGE_CONTENT;
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        {hero.title}
      </h1>
      <!-- <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a> -->
      <p class="mb-2">
        <strong>{hero.subtitle}</strong>
      </p>
      <p class="mt-6">{hero.paragraphs[0]}</p>
      <p class="mt-6">{hero.paragraphs[1]}</p>

      <!-- <p class="mt-2">
        Read the blog posts or check
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://github.com/satnaing/astro-paper#readme"
        >
          README
        </LinkButton> for more info.
      </p> -->
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">{hero.socialLabel}</div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class="pt-12 pb-6 border-b border-border"
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            Featured Projects
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>

          <div class="text-center">
            <LinkButton href="/posts/">
              All Projects
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    <!-- {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Projects</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    } -->

    <section id="about-home" class="border-b border-border pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">{about.title}</h2>
      <p class="my-6">{about.paragraphs[0]}</p>
      <p class="my-6">{about.paragraphs[1]}</p>
      <div class="text-center">
        <LinkButton href={about.cta.href}>
          {about.cta.text}
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <section id="currently-home" class="border-b border-border pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">{currently.title}</h2>
      <ul class="mt-5 list-disc space-y-3 ps-6">
        {currently.items.map(item => <li>{item}</li>)}
      </ul>
      <div class="mt-6 text-center">
        <LinkButton href={currently.cta.href}>
          {currently.cta.text}
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <section id="focus-areas-home" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">{focusAreas.title}</h2>
      <p class="mt-4">{focusAreas.text}</p>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
